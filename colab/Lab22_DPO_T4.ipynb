        "    print()\n",
        "\n",
        "    if last_gap < 0:\n",
        "        print(\"✗ FAILURE: reward gap went NEGATIVE. DPO did the opposite of what you wanted.\")\n",
        "        print(\"  Likely causes: data quality (chosen/rejected swapped?), beta too high, lr too low.\")\n",
        "    elif chosen_delta < -0.5 and last_gap > 0:\n",
