      "source": [
        "from datasets import load_dataset\n",
        "\n",
        "# Danh sách các bộ dữ liệu dự phòng\n",
        "possible_datasets = [\n",
        "    \"5CD-AI/Vietnamese-alpaca-gpt4-gg-translated\",\n",
        "    \"NlpHUST/vi-alpaca\",\n",
        "    \"Viet-Mistral/Alpaca-Vietnamese-70k\"\n",
        "]\n",
        "\n",
        "ds = None\n",
        "for repo in possible_datasets:\n",
        "    try:\n",
        "        print(f\"Đang thử tải: {repo}...\")\n",
        "        ds = load_dataset(repo, split=\"train\")\n",
        "        SFT_DATASET = repo # Lưu lại tên để dùng tiếp\n",
        "        print(f\"✅ Thành công với: {repo}\")\n",
        "        break\n",
        "    except Exception:\n",
        "        print(f\"❌ Không tìm thấy {repo}, đang thử bộ tiếp theo...\")\n",
        "\n",
        "if ds:\n",
        "    # Lấy slice dữ liệu như bạn muốn\n",
        "    SFT_SLICE = 1000\n",
        "    ds = ds.select(range(min(SFT_SLICE, len(ds))))\n",
        "    print(f\"Đã sẵn sàng với {len(ds)} dòng dữ liệu.\")\n",
        "else:\n",
        "    print(\"Không tải được bộ dữ liệu nào. Vui lòng kiểm tra kết nối mạng!\")"
      ]
    },
