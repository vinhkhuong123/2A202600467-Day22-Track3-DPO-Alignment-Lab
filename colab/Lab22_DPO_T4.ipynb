      "source": [
        "### 3b. Length distribution check\n",
        "\n",
        "Pairs longer than `MAX_LEN` will be truncated by the trainer. If too many are\n",
        "clipped, DPO loses signal. Aim for ≥ 80% of pairs fitting."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 42,
      "id": "fa5e2e06",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "fa5e2e06",
        "outputId": "34f93e4f-35d8-443e-8b00-ea5297b763b3"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Prompt:   median=87  P95=312\n",
            "Chosen:   median=400  P95=811\n",
            "Rejected: median=278  P95=792\n",
            "\n",
            "44.2% of pairs fit in MAX_LEN=512\n",
            "⚠  Less than 80% fit. Consider increasing MAX_LEN or filtering long pairs.\n"
          ]
        }
      ],
      "source": [
        "import numpy as np\n",
        "\n",
        "prompt_lens = np.array([len(tokenizer(p).input_ids) for p in pref[\"prompt\"]])\n",
        "chosen_lens = np.array([len(tokenizer(c).input_ids) for c in pref[\"chosen\"]])\n",
        "rejected_lens = np.array([len(tokenizer(r).input_ids) for r in pref[\"rejected\"]])\n",
        "\n",
        "total_len = prompt_lens + np.maximum(chosen_lens, rejected_lens)\n",
        "fit_pct = (total_len <= MAX_LEN).mean() * 100\n",
        "\n",
        "print(f\"Prompt:   median={np.median(prompt_lens):.0f}  P95={np.percentile(prompt_lens, 95):.0f}\")\n",
        "print(f\"Chosen:   median={np.median(chosen_lens):.0f}  P95={np.percentile(chosen_lens, 95):.0f}\")\n",
        "print(f\"Rejected: median={np.median(rejected_lens):.0f}  P95={np.percentile(rejected_lens, 95):.0f}\")\n",
        "print(f\"\\n{fit_pct:.1f}% of pairs fit in MAX_LEN={MAX_LEN}\")\n",
        "if fit_pct < 80:\n",
        "    print(\"⚠  Less than 80% fit. Consider increasing MAX_LEN or filtering long pairs.\")"
      ]
    },
