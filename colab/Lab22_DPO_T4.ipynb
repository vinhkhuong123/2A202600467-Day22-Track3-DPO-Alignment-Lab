   "source": [
    "from transformers import AutoModelForCausalLM\n",
    "from peft import PeftModel\n",
    "import torch, gc\n",
    "\n",
    "# Reload base in float16 on CPU — bypasses BNB quantization entirely\n",
    "print(\"Reloading base model in float16 on CPU (~2 min, dùng RAM không phải VRAM)...\")\n",
    "base = AutoModelForCausalLM.from_pretrained(\n",
    "    \"Qwen/Qwen2.5-3B\",          # original non-quantized model\n",
    "    torch_dtype=torch.float16,\n",
    "    device_map=\"cpu\",\n",
    ")\n",
    "base = PeftModel.from_pretrained(base, str(DPO_PATH))\n",
    "merged = base.merge_and_unload()\n",
    "merged.save_pretrained(str(MERGED_PATH), safe_serialization=True)\n",
    "tokenizer.save_pretrained(str(MERGED_PATH))\n",
    "print(f\"Saved merged FP16 to {MERGED_PATH}\")\n",
    "\n",
    "del base, merged\n",
    "gc.collect()\n",
    "torch.cuda.empty_cache()\n"
   ]
  },
