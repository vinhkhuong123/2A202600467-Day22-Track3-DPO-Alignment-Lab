      "source": [
        "## 3. Format with chat template\n",
        "\n",
        "DPO Trainer expects `prompt / chosen / rejected` columns. Each must already\n",
        "include the chat template tokens — Trainer doesn't apply template internally."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 40,
      "id": "6b8fbd16",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 66,
          "referenced_widgets": [
            "a582bd0ade7740cea84d5d20a3e30b56",
            "c7f986cba12d49e185ff05833bde17c3",
            "290fdb52cd4d436ebdd1db6031ce0482",
            "bda8c401efbf43a386671ccf865428b3",
            "cf653f4d582e40a6be3cdd5287862c00",
            "0c86949e0183467691e1b2723768719b",
            "f577f9767bff4c759cd1a66fe1bc79d8",
            "4a85c06f2bb64e4eb4ce3843e4c83a5a",
            "599fbe84c75a4efba9e662cc666f4abd",
            "b83b1e7bffa6494cbd7d12066973f0ec",
            "5ea95316c5ef4303a687574fd39b1771"
          ]
        },
        "id": "6b8fbd16",
        "outputId": "04e39650-bb95-48c2-d99b-9d5ba68f3109"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "Map:   0%|          | 0/2000 [00:00<?, ? examples/s]"
            ],
            "application/vnd.jupyter.widget-view+json": {
              "version_major": 2,
              "version_minor": 0,
              "model_id": "a582bd0ade7740cea84d5d20a3e30b56"
            }
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Formatted: 2000 pairs · cols: ['prompt', 'chosen', 'rejected']\n"
          ]
        }
      ],
      "source": [
        "def format_pref(row):\n",
        "    prompt_msgs = [{\"role\": \"user\", \"content\": row[\"prompt\"]}]\n",
        "    prompt_text = tokenizer.apply_chat_template(\n",
        "        prompt_msgs, tokenize=False, add_generation_prompt=True\n",
        "    )\n",
        "    # `chosen` and `rejected` in this dataset are list-of-dicts with role/content.\n",
        "    # Take just the assistant turn text (last message).\n",
        "    chosen_text = row[\"chosen\"][-1][\"content\"] if isinstance(row[\"chosen\"], list) else row[\"chosen\"]\n",
        "    rejected_text = row[\"rejected\"][-1][\"content\"] if isinstance(row[\"rejected\"], list) else row[\"rejected\"]\n",
        "    return {\n",
        "        \"prompt\": prompt_text,\n",
        "        \"chosen\": chosen_text,\n",
        "        \"rejected\": rejected_text,\n",
        "    }\n",
        "\n",
        "\n",
        "pref = ds.map(format_pref, remove_columns=ds.column_names)\n",
        "print(f\"Formatted: {len(pref)} pairs · cols: {pref.column_names}\")"
      ]
    },
