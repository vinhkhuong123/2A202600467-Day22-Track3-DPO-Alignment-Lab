        "gc.collect()\n",
        "torch.cuda.empty_cache()\n",
        "\n",
        "print(\">>> SFT+DPO on IFEval\")\n",
        "dpo_ifeval = run_lm_eval(DPO_PATH, \"ifeval\", LIMIT_IFEVAL, num_fewshot=0, label=\"dpo\")\n",
