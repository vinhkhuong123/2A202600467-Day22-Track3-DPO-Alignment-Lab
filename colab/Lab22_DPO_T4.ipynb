      "source": [
        "import torch\n",
        "\n",
        "assert torch.cuda.is_available(), \"DPO needs a CUDA GPU. See HARDWARE-GUIDE.md.\"\n",
        "gpu = torch.cuda.get_device_properties(0)\n",
        "print(f\"GPU: {gpu.name}  ({gpu.total_memory / 1e9:.1f} GB)\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "92df64cf",
